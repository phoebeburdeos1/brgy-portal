# Supabase (from project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Admin dashboard login (required for /admin)
ADMIN_PASSWORD=your-secret-password

# Email (Resend) – get key at https://resend.com
RESEND_API_KEY=re_...
# Optional: custom from address (default: Barangay Bonbon <onboarding@resend.dev>)
# EMAIL_FROM=Barangay Bonbon <noreply@yourdomain.com>
